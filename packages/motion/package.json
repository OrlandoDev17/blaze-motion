{
  "name": "@blaze-motion/motion",
  "version": "1.2.0",
  "description": "Preset de animaciones para motion/react",
  "homepage": "https://github.com/OrlandoDev17/blaze-motion",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OrlandoDev17/blaze-motion.git"
  },
  "bugs": {
    "url": "https://github.com/OrlandoDev17/blaze-motion/issues"
  },
  "keywords": [
    "animation",
    "motion",
    "react",
    "framer",
    "ui",
    "fade"
  ],
  "license": "MIT",
  "author": "Orlando López <orlandodev1707@gmail.com>",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "bun run typecheck && bun run build",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "motion": "^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "motion": {
      "optional": false,
      "version": "^12.0.0"
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
